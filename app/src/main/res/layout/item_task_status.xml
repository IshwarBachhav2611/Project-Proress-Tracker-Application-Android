<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:layout_marginHorizontal="4dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:rippleColor="#156366F1"
    app:strokeColor="#E2E8F0"
    app:strokeWidth="1.5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <FrameLayout
            android:layout_width="28dp"
            android:layout_height="28dp">
            <CheckBox
                android:id="@+id/cbTaskStatus"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:buttonTint="#6366F1"
                android:clickable="true"
                android:focusable="true"
                android:scaleX="1.1"
                android:scaleY="1.1" />
            <ImageView
                android:id="@+id/ivLockStatus"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_lock"
                android:visibility="gone"
                app:tint="#94A3B8" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTaskTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Task Title"
                android:textColor="#0F172A"
                android:textSize="15sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/tvTaskCreator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="#F1F5F9"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:text="ADMIN"
                    android:textColor="#475569"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"/>
                <TextView
                    android:id="@+id/tvAdminEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="admin@college.edu"
                    android:textColor="#64748B"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvAssignDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Assigned: Oct 12"
                    android:textColor="#3B82F6"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTaskDeadline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Due: Oct 20"
                    android:textColor="#EF4444"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenTask"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:padding="0dp"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            app:backgroundTint="#EEF2FF"
            app:cornerRadius="24dp"
            app:icon="@drawable/ic_upload"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="28dp"
            app:iconTint="#6366F1"
            app:iconTintMode="src_in" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>