<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="10dp">

    <TextView
        android:id="@+id/logDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="14 April, 02:30 PM"
        android:textColor="#94A3B8"
        android:textSize="10sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/logStatusIcon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_check_circle" />

        <TextView
            android:id="@+id/logUserEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="student@email.com"
            android:textColor="#1E293B"
            android:textStyle="bold"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/logFileName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:text="Uploaded: report_final.pdf"
        android:textColor="#6366F1"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/logTeacherFeedback"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="4dp"
        android:background="#FFF1F2"
        android:padding="8dp"
        android:text="Guide: Please correct the logic in section 2."
        android:textColor="#9F1239"
        android:textSize="12sp"
        android:visibility="visible" />
</LinearLayout>