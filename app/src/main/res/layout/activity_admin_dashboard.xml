<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/admin_main_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#0F172A"
            android:paddingHorizontal="24dp"
            android:paddingTop="52dp"
            android:paddingBottom="76dp">

            <LinearLayout
                android:id="@+id/headerTextGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_toStartOf="@+id/updateProfileBtn"
                android:layout_alignParentStart="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Admin Dashboard"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.02" />

                <TextView
                    android:id="@+id/welcomeMsg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Welcome back, Instructor"
                    android:textColor="#94A3B8"
                    android:textSize="14sp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/updateProfileBtn"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:backgroundTint="#1E293B"
                app:icon="@android:drawable/ic_menu_edit"
                app:iconTint="#6366F1"
                app:shapeAppearanceOverlay="@style/Widget.Material3.CircularProgressIndicator" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/headerTextGroup"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_input_field"
                android:backgroundTint="#1E293B"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CURRENT SESSION"
                        android:textColor="#64748B"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/classNameDisplay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No Class Active"
                        android:textColor="#F8FAFC"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/classInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input_field"
                    android:backgroundTint="#6366F1"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="---"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"/>
            </LinearLayout>
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-40dp"
            android:orientation="vertical"
            android:padding="20dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/groupsStatsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="24dp"
                app:cardElevation="10dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF"
                    android:orientation="horizontal"
                    android:paddingVertical="24dp"
                    android:weightSum="3">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <TextView android:id="@+id/studentCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#6366F1" android:textSize="24sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Students" android:textSize="10sp" android:textColor="#94A3B8" android:textStyle="bold" android:textAllCaps="true"/>
                    </LinearLayout>

                    <View android:layout_width="1dp" android:layout_height="32dp" android:background="#F1F5F9" android:layout_gravity="center"/>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <TextView android:id="@+id/teacherCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#6366F1" android:textSize="24sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Teachers" android:textSize="10sp" android:textColor="#94A3B8" android:textStyle="bold" android:textAllCaps="true"/>
                    </LinearLayout>

                    <View android:layout_width="1dp" android:layout_height="32dp" android:background="#F1F5F9" android:layout_gravity="center"/>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <TextView android:id="@+id/groupCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#6366F1" android:textSize="24sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Groups" android:textSize="10sp" android:textColor="#94A3B8" android:textStyle="bold" android:textAllCaps="true"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/createEditClassBtn"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="28dp"
                android:text="Manage Class Access"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="18dp"
                app:icon="@android:drawable/ic_menu_add"
                android:backgroundTint="#0F172A"
                app:elevation="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="12dp"
                android:text="SHARE &amp; NOTIFY"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:strokeWidth="1dp"
                app:strokeColor="#F1F5F9"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/shareClassBtn"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:gravity="start|center_vertical"
                        android:text="Copy Class Invitation"
                        android:textColor="#6366F1"
                        android:paddingStart="16dp"
                        app:icon="@android:drawable/ic_menu_share"
                        app:iconTint="#6366F1" />

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F8FAFC" android:layout_marginHorizontal="16dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/notifyBtn"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:gravity="start|center_vertical"
                        android:text="Send Announcements"
                        android:textColor="#334155"
                        android:paddingStart="16dp"
                        app:icon="@android:drawable/ic_dialog_info"
                        app:iconTint="#94A3B8" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="12dp"
                android:text="ACADEMIC MANAGEMENT"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:strokeWidth="1dp"
                app:strokeColor="#F1F5F9"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/assignTaskBtn"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:gravity="start|center_vertical"
                        android:text="Assign Tasks"
                        android:textColor="#334155"
                        android:paddingStart="16dp"
                        app:icon="@android:drawable/ic_menu_today"
                        app:iconTint="#94A3B8" />

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F8FAFC" android:layout_marginHorizontal="16dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/manageGroupsBtn"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:gravity="start|center_vertical"
                        android:text="Monitor Progress"
                        android:textColor="#334155"
                        android:paddingStart="16dp"
                        app:icon="@android:drawable/ic_menu_sort_by_size"
                        app:iconTint="#94A3B8" />

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F8FAFC" android:layout_marginHorizontal="16dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/manageUsersBtn"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:gravity="start|center_vertical"
                        android:text="Manage User Directory"
                        android:textColor="#334155"
                        android:paddingStart="16dp"
                        app:icon="@android:drawable/ic_menu_mylocation"
                        app:iconTint="#94A3B8" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/logoutBtn"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="48dp"
                android:layout_marginBottom="24dp"
                android:text="Sign Out"
                android:textColor="#E11D48"
                android:textStyle="bold"
                android:textAllCaps="false"
                app:backgroundTint="#FFF1F2"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_lock_power_off"
                app:iconTint="#E11D48"
                app:iconGravity="textStart"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>